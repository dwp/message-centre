{% extends "layouts/main.html" %}

{% block header %}


  {{ govukOneLoginServiceHeader({
    homepageLink: "/index.html",
    signOutLink: " ",
    oneLoginLink: " ",
    
    serviceNavigationParams: { 
      
      serviceName: "View your letters and messages",
      navigationLabel: "inbox.html"
      
    }
  }) }}


{% endblock %}

{% block pageTitle %}
  View your letters and messages
{% endblock %}

{% block beforeContent %}
  <ul class="dwp-language-toggle__list">
    <li class="dwp-language-toggle__list-item" aria-current="true"> <span class="govuk-body-s"> English  </span></li>
    <li class="dwp-language-toggle__list-item">    
    <a href="#" hreflang="cy" lang="cy" rel="alternate" class="govuk-link--no-visited-state" aria-label="Newid yr iaith ir Gymraeg">Cymraeg</a>
    </li>
  </ul>

  {{ govukBackLink({
    text: "Back",
    href: "javascript:window.history.back()"
  }) }}
{% endblock %}

{% block content %}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <form class="form" action="address-on-your-digital-copy" method="post">

        {% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}

        {% from "govuk/components/radios/macro.njk" import govukRadios %}

{{ govukRadios({
  name: "howLetter",
  fieldset: {
    legend: {
      text: "What kind of proof of benefit letter do you need?",
      isPageHeading: true,
      classes: "govuk-fieldset__legend--l"
    }
  },
  items: [
    {
      value: "Downloadable digital letter",
      text: "Downloadable digital letter"
    },
    {
      value: "Printed letter",
      text: "Printed letter",
      hint: {
        text: "Posted to your address"
      }
    },
    {
      value: "Both a digital letter and a printed letter",
      text: "Both a digital letter and a printed letter"
    }
  ]
}) }}



        {{ govukButton({
          text: "Continue"
        }) }}

      </form>

    </div>
  </div>

{% endblock %}