{% extends "layouts/main.html" %}

{% block header %}


  {{ govukOneLoginServiceHeader({
  signOutLink: " "}) }}

  {{ govukServiceNavigation({
    serviceName: "View your letters and messages",
    serviceUrl: "/index"
  }) }}


{% endblock %}

{% block pageTitle %}
  View your letters and messages
{% endblock %}

{% block beforeContent %}
  <ul class="dwp-language-toggle__list">
    <li class="dwp-language-toggle__list-item" aria-current="true"> <span class="govuk-body-s"> English  </span></li>
    <li class="dwp-language-toggle__list-item">    
    <a href="#" hreflang="cy" lang="cy" rel="alternate" class="govuk-link--no-visited-state" aria-label="Newid yr iaith ir Gymraeg">Cymraeg</a>
    </li>
  </ul>

  {{ govukBackLink({
    text: "Back",
    href: "javascript:window.history.back()"
  }) }}
{% endblock %}

{% block content %}

  <!-- This page is shown when a user has no benefits in their account
       It is triggered by the list-benefits-answer route when researchSetUpBenefits 
       is either empty or undefined -->
       <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
    
          <h1 class="govuk-heading-l">
            Contact us
          </h1>
    
            <p>
              We cannot find a record of the benefits you currently get.
            </p>
    
            <p>
              If you think this is wrong, contact the benefit that pays you.
            </p>
    
            <p>
              Find their contact details in a letter they’ve sent to you, or in <a href="https://www.gov.uk/browse/benefits" class="govuk-link" rel="noreferrer noopener" target="_blank">guidance about the benefit on GOV.UK (opens in a new tab)</a>.
            </p>
    
            <div class="govuk-button-group">
              {{ govukButton({
                text: "Sign out",
                href: "signout"
              }) }}
    
              {{ govukButton({
                text: "Go back to account home",
                href: "account-home",
                classes: "govuk-button--secondary"
              }) }}
            </div>
    
        </div>
      </div>
{% endblock %}