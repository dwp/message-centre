{% extends "layouts/main.html" %}

{% block header %}


  {{ govukOneLoginServiceHeader({
    homepageLink: "/index.html",
    signOutLink: " ",
    oneLoginLink: " ",
    
    serviceNavigationParams: { 
      
      serviceName: "View your letters and messages",
      navigationLabel: "inbox.html"
      
    }
  }) }}


{% endblock %}

{% block pageTitle %}
  View your letters and messages
{% endblock %}

{% block beforeContent %}
  <ul class="dwp-language-toggle__list">
    <li class="dwp-language-toggle__list-item" aria-current="true"> <span class="govuk-body-s"> English  </span></li>
    <li class="dwp-language-toggle__list-item">    
    <a href="#" hreflang="cy" lang="cy" rel="alternate" class="govuk-link--no-visited-state" aria-label="Newid yr iaith ir Gymraeg">Cymraeg</a>
    </li>
  </ul>

  {{ govukBackLink({
    text: "Back",
    href: "javascript:window.history.back()"
  }) }}
{% endblock %}

{% block content %}





<div class="govuk-!-padding-bottom-2"></div>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">

        <h1 class="govuk-heading-xl">Example email</h1>

          <p>Dear John Smith,</p>

          <p>This is an example of how emails will be displayed when you check your notifications.</p>
            <p>There is no other information. We are just using this text as an example.</p>

            <p>All the best,<br>Sender</p>

        <div class="govuk-!-padding-bottom-6"></div>
        <div class="govuk-button-group">
        <button class="govuk-button" value= "true" data-module="govuk-button" style="margin-bottom:50px;" onclick="check3()" >Download</button>
        <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">
          Print
        </button>
        </div>


</div>

<div class="govuk-grid-column-one-third" style="text-align: left;">

    <div class="govuk-!-padding-bottom-2"></div>

  <style>
    .dwp-logo {max-width: 135px}
    .dwp-logo {max-height: 113.5px}
  
    /* .dwp-logo {
          float: right;
      } */
  
    </style>
  
  <img src="/public/images/dwp-logo.png" class="dwp-logo">

  </div>
  
  </div>
  </div>


  

<style>

  .govuk-grid-column-two-thirds,
  .govuk-grid-column-one-third, {
    float: left;
    width: 66.66%;
  }

  .govuk-grid-column-one-third {
    width: 33.33%;
  }

  @media (max-width: 768px) {
  .govuk-grid-column-two-thirds,
  .govuk-grid-column-one-third {
    float: none;
    width: 100%;
  } 
  }

.govuk-heading-xl {
          padding-bottom: 10px;
        }

</style>


{% endblock %}
