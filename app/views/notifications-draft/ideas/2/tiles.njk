{% extends "layouts/main.html" %}

{% block header %}


  {{ govukOneLoginServiceHeader({
    homepageLink: "/index.html",
    signOutLink: " ",
    oneLoginLink: " ",
    
    serviceNavigationParams: { 
      
      serviceName: "View your letters and messages",
      navigationLabel: "inbox.html"
      
    }
  }) }}


{% endblock %}

{% block pageTitle %}
  View your letters and messages
{% endblock %}

{% block beforeContent %}
  <ul class="dwp-language-toggle__list">
    <li class="dwp-language-toggle__list-item" aria-current="true"> <span class="govuk-body-s"> English  </span></li>
    <li class="dwp-language-toggle__list-item">    
    <a href="#" hreflang="cy" lang="cy" rel="alternate" class="govuk-link--no-visited-state" aria-label="Newid yr iaith ir Gymraeg">Cymraeg</a>
    </li>
  </ul>

  {{ govukBackLink({
    text: "Back",
    href: "javascript:window.history.back()"
  }) }}
{% endblock %}

{% block content %}


<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl">View your notifications</h1>
      </div>
    </div>
    <div class="govuk-tabs" data-module="govuk-tabs">

    <div>
      <ul class="govuk-grid-row customer-view-card-group">
        <li class="govuk-grid-column-one-third customer-view-card-group__item">
          <div class="customer-view-card customer-view-card--clickable">
            <div class="customer-view-card__content">
              <h2 class="customer-view-card__heading govuk-heading-m">
                <a class="govuk-link govuk-link--no-visited-state customer-view-card__link" href="carers-allowance.njk">Carer's Allowance</a>
              </h2>
            </div>
          </div>
        </li>
        <li class="govuk-grid-column-one-third customer-view-card-group__item">
          <div class="customer-view-card customer-view-card--clickable">
            <div class="customer-view-card__content">
              <h2 class="customer-view-card__heading govuk-heading-m">
                <a class="govuk-link govuk-link--no-visited-state customer-view-card__link" href="child-maintenance.njk">Child Maintenance	</a>
              </h2>
            </div>
          </div>
        </li>
        <li class="govuk-grid-column-one-third customer-view-card-group__item">
          <div class="customer-view-card customer-view-card--clickable">
            <div class="customer-view-card__content">
              <h2 class="customer-view-card__heading govuk-heading-m">
                <a class="govuk-link govuk-link--no-visited-state customer-view-card__link" href="esa.njk">Employment Support Allowance (ESA)</a>&nbsp<span id="notifications" class="moj-notification-badge">1</span>

              </h2>
            </div>
          </div>
        </li>
        <li class="govuk-grid-column-one-third customer-view-card-group__item">
          <div class="customer-view-card customer-view-card--clickable">
            <div class="customer-view-card__content">
              <h2 class="customer-view-card__heading govuk-heading-m">
                <a class="govuk-link govuk-link--no-visited-state customer-view-card__link" href="pip.njk">Personal Independence Payment</a>&nbsp<span id="notifications" class="moj-notification-badge">1</span>
              </h2>
            </div>
          </div>
        </li>
      </ul>
    </div>
    </div>
  </div>
</div>


{% endblock %}